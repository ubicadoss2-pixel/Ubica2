// Prisma schema actualizado para MySQL y modelo Ubica2

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum PlaceStatus {
  DRAFT
  PUBLISHED
  SUSPENDED
}

enum PlaceContactType {
  WHATSAPP
  PHONE
  EMAIL
  WEBSITE
}

enum PlaceSocialPlatform {
  INSTAGRAM
  FACEBOOK
  TIKTOK
  X
  YOUTUBE
  OTHER
}

enum EventStatus {
  ACTIVE
  CANCELLED
  SUSPENDED
}

enum EventDateType {
  OCCURRENCE
  EXCEPTION
}

enum ReportTargetType {
  PLACE
  EVENT
}

enum ReportReason {
  WRONG_INFO
  SPAM
  INAPPROPRIATE
  CLOSED
  OTHER
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
}

enum CommentStatus {
  VISIBLE
  EDITED
  HIDDEN
  BLOCKED
}

enum AnalyticsEventType {
  PLACE_VIEW
  EVENT_VIEW
  CONTACT_CLICK
  FAVORITE_ADD
  FAVORITE_REMOVE
  REPORT_CREATE
}

model Role {
  id          String    @id @default(uuid())
  code        String    @unique @db.VarChar(50)
  name        String    @db.VarChar(100)
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  userRoles   UserRole[]

  @@map("roles")
}

model City {
  id          String   @id @default(uuid())
  countryCode String   @db.Char(2) @map("country_code")
  name        String   @db.VarChar(120)
  stateRegion String?  @db.VarChar(120) @map("state_region")
  timezone    String   @db.VarChar(64) @default("America/Bogota")
  createdAt   DateTime @default(now()) @map("created_at")
  places      Place[]

  @@unique([countryCode, name, stateRegion])
  @@map("cities")
}

model PlaceType {
  id        String   @id @default(uuid())
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  places    Place[]

  @@map("place_types")
}

model EventCategory {
  id        String   @id @default(uuid())
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  events    Event[]

  @@map("event_categories")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique @db.VarChar(254)
  phone        String?   @db.VarChar(30)
  passwordHash String?   @map("password_hash")
  fullName     String?   @db.VarChar(160) @map("full_name")
  avatarUrl    String?   @db.VarChar(500) @map("avatar_url")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  userRoles    UserRole[]
  places       Place[]   @relation("PlaceOwner")
  favorites    Favorite[]
  reports      Report[]
  comments     Comment[] @relation("CommentAuthor")
  moderatedComments Comment[] @relation("CommentModerator")
  analytics    AnalyticsEvent[]
  auditLogs    AuditLog[]
  userSubscriptions UserPlan[] @relation("UserPlansRelation")

  @@map("users")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Place {
  id           String      @id @default(uuid())
  ownerUserId  String?     @map("owner_user_id")
  cityId       String      @map("city_id")
  placeTypeId  String      @map("place_type_id")
  name         String      @db.VarChar(180)
  slug         String      @db.VarChar(220)
  description  String?
  addressLine  String?     @db.VarChar(240) @map("address_line")
  neighborhood String?     @db.VarChar(140)
  postalCode   String?     @db.VarChar(20) @map("postal_code")
  latitude     Decimal?    @db.Decimal(9, 6)
  longitude    Decimal?    @db.Decimal(9, 6)
  priceLevel   Int?        @map("price_level")
  status       PlaceStatus @default(DRAFT)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")

  ownerUser    User?         @relation("PlaceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  city         City          @relation(fields: [cityId], references: [id], onDelete: Restrict)
  placeType    PlaceType     @relation(fields: [placeTypeId], references: [id], onDelete: Restrict)
  contacts     PlaceContact[]
  socialLinks  PlaceSocialLink[]
  photos       PlacePhoto[]
  openingHours OpeningHour[]
  events       Event[]
  favorites    Favorite[]
  reports      Report[]
  comments     Comment[]
  analytics    AnalyticsEvent[]

  @@unique([cityId, slug])
  @@index([cityId, placeTypeId])
  @@index([status])
  @@index([latitude, longitude])
  @@map("places")
}

model PlaceContact {
  id          String           @id @default(uuid())
  placeId     String           @map("place_id")
  contactType PlaceContactType @map("contact_type")
  label       String?          @db.VarChar(80)
  value       String           @db.VarChar(240)
  isPrimary   Boolean          @default(false) @map("is_primary")
  createdAt   DateTime         @default(now()) @map("created_at")
  place       Place            @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@map("place_contacts")
}

model PlaceSocialLink {
  id        String              @id @default(uuid())
  placeId   String              @map("place_id")
  platform  PlaceSocialPlatform
  url       String              @db.VarChar(400)
  createdAt DateTime            @default(now()) @map("created_at")
  place     Place               @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@map("place_social_links")
}

model PlacePhoto {
  id        String   @id @default(uuid())
  placeId   String   @map("place_id")
  url       String   @db.VarChar(500)
  altText   String?  @db.VarChar(200) @map("alt_text")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@map("place_photos")
}

model OpeningHour {
  id        String   @id @default(uuid())
  placeId   String   @map("place_id")
  weekday   Int
  openTime  DateTime? @db.Time @map("open_time")
  closeTime DateTime? @db.Time @map("close_time")
  isClosed  Boolean  @default(false) @map("is_closed")
  createdAt DateTime @default(now()) @map("created_at")
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, weekday])
  @@map("opening_hours")
}

model Event {
  id          String       @id @default(uuid())
  placeId     String       @map("place_id")
  categoryId  String?      @map("category_id")
  title       String       @db.VarChar(200)
  description String?
  addressLine String?      @db.VarChar(240) @map("address_line")
  neighborhood String?     @db.VarChar(140)
  postalCode  String?      @db.VarChar(20) @map("postal_code")
  latitude    Decimal?     @db.Decimal(9, 6)
  longitude   Decimal?     @db.Decimal(9, 6)
  dressCode   String?      @db.VarChar(120) @map("dress_code")
  minAge      Int?         @map("min_age")
  currency    String       @default("COP") @db.Char(3)
  priceFrom   Decimal?     @db.Decimal(12, 2) @map("price_from")
  priceTo     Decimal?     @db.Decimal(12, 2) @map("price_to")
  startTime   DateTime     @db.Time @map("start_time")
  endTime     DateTime?    @db.Time @map("end_time")
  status      EventStatus  @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  place       Place         @relation(fields: [placeId], references: [id], onDelete: Cascade)
  category    EventCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recurrence  EventRecurrence?
  specialDates EventSpecialDate[]
  reports     Report[]
  comments    Comment[]
  analytics   AnalyticsEvent[]
  photos      EventPhoto[]

  @@index([placeId])
  @@index([categoryId])
  @@index([status])
  @@map("events")
}

model EventRecurrence {
  eventId   String   @id @map("event_id")
  weekday   Int
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_recurrences")
}

model EventPhoto {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  url       String   @db.VarChar(500)
  altText   String?  @db.VarChar(200) @map("alt_text")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_photos")
}

model EventSpecialDate {
  id        String       @id @default(uuid())
  eventId   String       @map("event_id")
  eventDate DateTime     @db.Date @map("event_date")
  dateType  EventDateType @default(OCCURRENCE) @map("date_type")
  note      String?      @db.VarChar(250)
  createdAt DateTime     @default(now()) @map("created_at")
  event     Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, eventDate, dateType])
  @@index([eventDate])
  @@index([eventId])
  @@map("event_special_dates")
}

model Favorite {
  userId   String   @map("user_id")
  placeId  String   @map("place_id")
  createdAt DateTime @default(now()) @map("created_at")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  place    Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([userId, placeId])
  @@map("favorites")
}

model Report {
  id         String          @id @default(uuid())
  userId     String?         @map("user_id")
  targetType ReportTargetType @map("target_type")
  placeId    String?         @map("place_id")
  eventId    String?         @map("event_id")
  reason     ReportReason
  details    String?
  status     ReportStatus    @default(OPEN)
  createdAt  DateTime        @default(now()) @map("created_at")
  resolvedAt DateTime?       @map("resolved_at")
  user       User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  place      Place?          @relation(fields: [placeId], references: [id], onDelete: Cascade)
  event      Event?          @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([placeId])
  @@index([eventId])
  @@map("reports")
}

model Comment {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  placeId      String?       @map("place_id")
  eventId      String?       @map("event_id")
  content      String        @db.VarChar(1000)
  rating       Int?          @db.TinyInt // 1 to 5
  status       CommentStatus @default(VISIBLE)
  moderatedById String?      @map("moderated_by_id")
  moderatedAt  DateTime?     @map("moderated_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")

  user         User          @relation("CommentAuthor", fields: [userId], references: [id], onDelete: Cascade)
  place        Place?        @relation(fields: [placeId], references: [id], onDelete: SetNull)
  event        Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  moderatedBy  User?         @relation("CommentModerator", fields: [moderatedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
  @@index([placeId])
  @@index([eventId])
  @@index([moderatedById])
  @@map("comments")
}

model AnalyticsEvent {
  id         String             @id @default(uuid())
  userId     String?            @map("user_id")
  eventType  AnalyticsEventType @map("event_type")
  placeId    String?            @map("place_id")
  eventId    String?            @map("event_id")
  meta       Json?
  occurredAt DateTime           @default(now()) @map("occurred_at")
  user       User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  place      Place?             @relation(fields: [placeId], references: [id], onDelete: SetNull)
  event      Event?             @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([placeId])
  @@index([eventId])
  @@map("analytics_events")
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?  @map("actor_user_id")
  entityId    String   @map("entity_id")
  action      String   @db.VarChar(60)
  entityType  String   @db.VarChar(30) @map("entity_type")
  beforeData  Json?    @map("before_data")
  afterData   Json?    @map("after_data")
  createdAt   DateTime @default(now()) @map("created_at")
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Plan {
  id           String      @id @default(uuid())
  name         String      @db.VarChar(100)
  limitPlaces  Int         @map("limit_places")
  limitEvents  Int         @map("limit_events")
  price        Decimal     @db.Decimal(10, 2)
  durationDays Int         @map("duration_days")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  userPlans    UserPlan[]

  @@map("plans")
}

model UserPlan {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  planId    String   @map("plan_id")
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation("UserPlansRelation", fields: [userId], references: [id], onDelete: Cascade)
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([planId])
  @@index([isActive])
  @@map("user_plans")
}
